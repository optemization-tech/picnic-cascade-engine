# === Token Pools (separate Notion integrations per operation) ===

# Cascade pool — date-cascade, status-rollup (user-facing, latency-sensitive)
NOTION_TOKEN_1=ntn_xxxxx
# NOTION_TOKEN_2=ntn_yyyyy

# Provisioning pool — inception, add-task-set, copy-blocks (bulk operations)
# NOTION_PROVISION_TOKEN_1=ntn_xxxxx
# NOTION_PROVISION_TOKEN_2=ntn_yyyyy

# Deletion pool — destructive dev utility (fully isolated)
# NOTION_DELETION_TOKEN_1=ntn_xxxxx

# Comment pool — dedicated integration for study page comments + activity log (distinct identity)
# NOTION_COMMENT_TOKEN_1=ntn_xxxxx

# === Notion Database IDs ===
STUDY_TASKS_DB_ID=40f2386760c2830eaad68159ca69a8d6
STUDIES_DB_ID=cad2386760c2836fa27d0131c25b6dcd
BLUEPRINT_DB_ID=8fe2386760c283e9a95d01ade939f5c2
ACTIVITY_LOG_DB_ID=f512386760c282269d66810554f3ec81

# === Webhook Auth ===
# Set AFTER updating all Notion automations to send X-Webhook-Secret header
# WEBHOOK_SECRET=your-secret-here

# === Server ===
PORT=3000
NODE_ENV=development
